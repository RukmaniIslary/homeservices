# Database (get from neon.tech)
DATABASE_URL="postgresql://username:password@ep-your-db.neon.tech/neondb?sslmode=require"

# Paddle (get from vendors.paddle.com → Developer → Authentication)
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="your_paddle_client_token"
PADDLE_API_KEY="your_paddle_api_key"
PADDLE_WEBHOOK_SECRET="your_paddle_webhook_secret"
NEXT_PUBLIC_PADDLE_ENV="production"

# App
NEXT_PUBLIC_APP_URL="https://www.n-nodes.com"
NEXT_PUBLIC_BRAND_NAME="N-Nodes"
NEXT_PUBLIC_BRAND_EMAIL="support@n-nodes.com"

# Admin (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ADMIN_SECRET_KEY="your_secure_random_string"
NEXTAUTH_SECRET="your_nextauth_secret"
